{
  "version": 2,
  "builds": [
    { "src": "api/api.py", "use": "@vercel/python", "config": { "maxDuration": 30 } },
    { "src": "hotel-dashboard/frontend/**/*", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/api.py" },
    { "src": "/(.*)", "dest": "/hotel-dashboard/frontend/$1" }
  ]
}