{
  "version": 2,
  "builds": [
    { "src": "api/register.py", "use": "@vercel/python" },
    { "src": "api/login.py", "use": "@vercel/python" }
  ],
  "routes": [
    { "src": "/api/register", "dest": "/api/register.py" },
    { "src": "/api/login", "dest": "/api/login.py" },
    { "src": "/(.*)", "dest": "/hotel-dashboard/frontend/$1" }
  ]
}